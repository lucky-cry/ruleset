{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "experimental": {
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://cdn.jsdelivr.net/gh/MetaCubeX/Yacd-meta@archive/gh-pages.zip",
      "external_ui_download_detour": "🎯 全球直连",
      "default_mode": "rule"
    }
  },

  "dns": {
    "strategy": "prefer_ipv4",
    "independent_cache": true,

    "servers": [
      {
        "tag": "localDns",
        "address": "127.0.0.1",
        "detour": "🎯 全球直连"
      },
      {
        "tag": "proxyDns",
        "address": "tls://8.8.8.8",
        "detour": "🚀 节点选择"
      },
      {
        "tag": "fakeip",
        "address": "fakeip"
      },
      {
        "tag": "block",
        "address": "rcode://success"
      }
    ],

    "rules": [
      {
        "rule_set": "geosite-cn",
        "server": "localDns"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "server": "proxyDns"
      }
    ],

    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    },

    "final": "localDns"
  },

  "inbounds": [
    {
      "type": "tun",
      "inet4_address": "172.19.0.1/30",
      "mtu": 9000,
      "auto_route": true,
      "strict_route": true,
      "sniff": true,
      "endpoint_independent_nat": false,
      "stack": "system",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "0.0.0.0",
          "server_port": 2080
        }
      }
    },
    {
      "type": "mixed",
      "listen": "0.0.0.0",
      "listen_port": 2080,
      "sniff": true
    }
  ],

